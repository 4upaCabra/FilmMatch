# Database
POSTGRES_USER=user
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=movie_matcher
DATABASE_URL=postgresql://user:CHANGE_ME_IN_PRODUCTION@db:5432/movie_matcher

# TMDB API (получите на https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_api_key_here
TMDB_BEARER_TOKEN=your_bearer_token_here
TMDB_PROXY_URL=

# JWT Secret (смените на случайную строку в продакшене!)
JWT_SECRET=your-secret-key-change-in-production

# Frontend URL (для CORS)
FRONTEND_URL=http://localhost:3000
